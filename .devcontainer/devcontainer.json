{
  "name": "Lane-Assisted VO",

  // Path is relative to .devcontainer/ folder — goes up one level to docker/
  "dockerComposeFile": ["../docker/docker-compose.yml"],
  "service": "ml-dev",
  "workspaceFolder": "/workspace",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.pylance",
        "ms-python.debugpy",
        "ms-toolsai.jupyter",
        "ms-toolsai.jupyter-keymap",
        "ms-toolsai.jupyter-renderers",
        "ms-python.black-formatter",
        "ms-python.isort",
        "eamodio.gitlens",
        "github.vscode-pull-request-github",
        "njpwerner.autodocstring",
        "christian-kohler.path-intellisense",
        "visualstudioexptteam.vscodeintellicode"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/bin/python3",
        "python.formatting.provider": "black",
        "editor.formatOnSave": true,
        "editor.rulers": [88],
        "terminal.integrated.defaultProfile.linux": "bash",
        "jupyter.notebookFileRoot": "/workspace/notebooks"
      }
    }
  },

  "forwardPorts": [8888, 6006],
  "portsAttributes": {
    "8888": { "label": "JupyterLab" },
    "6006": { "label": "TensorBoard" }
  },

  "postStartCommand": "pip install -e . --quiet 2>/dev/null || true",
  "remoteUser": "root"
}
